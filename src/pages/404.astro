---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Página não encontrada — PortaFácil">
  <Header />
  <main class="section bg-gray-50 min-h-[60vh] flex items-center">
    <div class="container text-center">
      <p class="text-8xl font-black text-gray-200 mb-4">404</p>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">Página não encontrada</h1>
      <p class="text-gray-500 mb-8">A página que você está procurando não existe ou foi movida.</p>
      <a href="/" class="btn-primary">Voltar para o início</a>
    </div>
  </main>
  <Footer />
</BaseLayout>
