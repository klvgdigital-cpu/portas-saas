---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { PROFISSIONAIS_MOCK } from '../types/index';

const profSlug = Astro.url.searchParams.get('profissional');
const prof = profSlug ? PROFISSIONAIS_MOCK.find(p => p.slug === profSlug) : null;
---

<BaseLayout
  title="Solicitar Orçamento — PortaFácil"
  description="Solicite um orçamento gratuito para instalação ou manutenção de porta de enrolar."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    ...(prof ? [{ label: prof.nome, href: `/profissionais/${prof.slug}` }] : []),
    { label: 'Orçamento', href: '/orcamento' },
  ]}
>
  <Header />
  <main class="bg-gray-50 min-h-screen py-12">
    <div class="container max-w-lg mx-auto">
      <div class="text-center mb-8">
        <h1 class="font-display font-bold text-2xl md:text-3xl text-brand-navy mb-2">
          Solicitar orçamento
        </h1>
        {prof ? (
          <p class="text-gray-500 text-sm">Para <strong class="text-gray-800">{prof.nome}</strong> em {prof.cidade}, {prof.estado}</p>
        ) : (
          <p class="text-gray-500 text-sm">Preencha os dados abaixo e o profissional entrará em contato.</p>
        )}
      </div>

      <form id="form-orcamento" class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 space-y-5" novalidate>
        {prof && <input type="hidden" name="profissional_id" value={prof.id} />}

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="nome_cliente">Seu nome *</label>
            <input type="text" id="nome_cliente" name="nome" required placeholder="Nome completo"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue min-h-[48px]" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="telefone">Telefone/WhatsApp *</label>
            <input type="tel" id="telefone" name="telefone" required placeholder="(11) 99999-0000"
              class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue min-h-[48px]" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email_cliente">E-mail</label>
          <input type="email" id="email_cliente" name="email" placeholder="seu@email.com"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue min-h-[48px]" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="cidade_cliente">Cidade *</label>
          <input type="text" id="cidade_cliente" name="cidade" required placeholder="Sua cidade"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue min-h-[48px]" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Tipo de serviço *</label>
          <div class="grid grid-cols-2 gap-3">
            {[
              'Manutenção / reparo',
              'Instalação nova',
              'Troca de motor',
              'Troca de mola',
              'Revisão preventiva',
              'Outro',
            ].map(tipo => (
              <label class="cursor-pointer">
                <input type="radio" name="tipo_servico" value={tipo} class="sr-only peer" />
                <div class="py-2.5 px-3 border border-gray-200 rounded-xl text-xs font-medium text-gray-700 peer-checked:border-brand-blue peer-checked:bg-blue-50 peer-checked:text-brand-blue transition-all text-center">
                  {tipo}
                </div>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="descricao_problema">Descreva o problema *</label>
          <textarea id="descricao_problema" name="descricao" required rows="4"
            placeholder="Ex: Porta de enrolar automática não abre mais, motor faz barulho..."
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue resize-none"></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="data_preferida">Data preferida (opcional)</label>
          <input type="date" id="data_preferida" name="data_preferida"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue min-h-[48px] bg-white" />
        </div>

        <button type="submit" class="w-full bg-brand-orange hover:bg-orange-600 text-white font-semibold py-4 rounded-xl transition-colors text-sm min-h-[52px]">
          Enviar solicitação de orçamento
        </button>

        <p class="text-center text-xs text-gray-400">
          Seus dados são protegidos e usados apenas para contato do profissional.
        </p>
      </form>
    </div>
  </main>
  <Footer />
</BaseLayout>
