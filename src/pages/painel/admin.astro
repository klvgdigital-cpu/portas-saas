---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="Painel ADM — PortaFácil" description="Área restrita.">
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-6xl">

      <div id="loading" class="text-center py-20">
        <div class="inline-block animate-spin rounded-full h-10 w-10 border-4 border-orange-500 border-t-transparent"></div>
        <p class="text-gray-500 mt-4">Verificando acesso...</p>
      </div>

      <div id="negado" class="hidden text-center py-20">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Área restrita</h1>
        <p class="text-gray-500 mb-6">Você não tem permissão para acessar esta página.</p>
        <a href="/" class="btn-primary">Voltar ao início</a>
      </div>

      <div id="dash" class="hidden">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">📊 Painel ADM — PortaFácil</h1>

        <!-- Cards de métricas -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
          <div class="card text-center"><p class="text-2xl font-bold" id="m-leads-total">0</p><p class="text-xs text-gray-500">Leads (total)</p></div>
          <div class="card text-center"><p class="text-2xl font-bold" id="m-leads-7d">0</p><p class="text-xs text-gray-500">Leads (7 dias)</p></div>
          <div class="card text-center"><p class="text-2xl font-bold" id="m-leads-30d">0</p><p class="text-xs text-gray-500">Leads (30 dias)</p></div>
          <div class="card text-center"><p class="text-2xl font-bold text-green-600" id="m-ativos">0</p><p class="text-xs text-gray-500">Profis. ativos</p></div>
          <div class="card text-center"><p class="text-2xl font-bold text-gray-400" id="m-pendentes">0</p><p class="text-xs text-gray-500">Ocultos/pend.</p></div>
          <div class="card text-center"><p class="text-2xl font-bold text-orange-600" id="m-receita">R$ 0</p><p class="text-xs text-gray-500">Receita potencial/mês</p></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
          <!-- Leads por região -->
          <div class="card">
            <h2 class="font-bold text-gray-900 mb-4">📍 Demanda por região</h2>
            <div id="regioes-lista" class="space-y-2"></div>
            <p id="regioes-vazio" class="hidden text-sm text-gray-400">Nenhum lead registrado ainda.</p>
          </div>

          <!-- Profissionais -->
          <div class="card">
            <h2 class="font-bold text-gray-900 mb-4">👷 Profissionais</h2>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead><tr class="text-left text-xs text-gray-500 border-b"><th class="pb-2">Nome</th><th class="pb-2">Status</th><th class="pb-2">Leads</th><th class="pb-2">Último lead</th></tr></thead>
                <tbody id="prof-tabela"></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Últimos leads -->
        <div class="card">
          <h2 class="font-bold text-gray-900 mb-4">📩 Últimos leads</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="text-left text-xs text-gray-500 border-b"><th class="pb-2 pr-3">Data</th><th class="pb-2 pr-3">Cliente</th><th class="pb-2 pr-3">Telefone</th><th class="pb-2 pr-3">Região</th><th class="pb-2 pr-3">Serviço</th></tr></thead>
              <tbody id="leads-tabela"></tbody>
            </table>
          </div>
          <p id="leads-vazio" class="hidden text-sm text-gray-400 mt-2">Nenhum lead registrado ainda.</p>
        </div>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const sbUrl = document.querySelector('meta[name="sb-url"]')?.getAttribute('content') || '';
  const sbKey = document.querySelector('meta[name="sb-key"]')?.getAttribute('content') || '';

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
  function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }
  function setText(id: string, t: string) { const el = document.getElementById(id); if (el) el.textContent = t; }
  const fmtData = (d: string) => new Date(d).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });

  (async () => {
    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(sbUrl, sbKey);
      const { data: { session } } = await supabase.auth.getSession();
      hide('loading');
      if (!session) { show('negado'); return; }

      const res = await fetch('/api/admin-dados', { headers: { 'Authorization': `Bearer ${session.access_token}` } });
      if (!res.ok) { show('negado'); return; }
      const data = await res.json();

      const m = data.metricas;
      setText('m-leads-total', String(m.leads_total));
      setText('m-leads-7d', String(m.leads_7d));
      setText('m-leads-30d', String(m.leads_30d));
      setText('m-ativos', String(m.profissionais_ativos));
      setText('m-pendentes', String(m.profissionais_pendentes));
      setText('m-receita', 'R$ ' + m.receita_potencial.toLocaleString('pt-BR'));

      // Regiões
      const regioes = Object.entries(data.leads_por_regiao || {}).sort((a: any, b: any) => b[1] - a[1]);
      const maxR = regioes.length ? (regioes[0][1] as number) : 1;
      const rl = document.getElementById('regioes-lista')!;
      if (regioes.length === 0) show('regioes-vazio');
      regioes.forEach(([nome, qtd]: any) => {
        const pct = Math.round((qtd / maxR) * 100);
        rl.insertAdjacentHTML('beforeend',
          `<div class="flex items-center gap-2 text-sm">
            <span class="w-40 truncate text-gray-700">${nome}</span>
            <div class="flex-1 bg-gray-100 rounded-full h-3"><div class="bg-orange-500 h-3 rounded-full" style="width:${pct}%"></div></div>
            <span class="w-8 text-right font-medium">${qtd}</span>
          </div>`);
      });

      // Profissionais
      const pt = document.getElementById('prof-tabela')!;
      (data.profissionais || []).forEach((p: any) => {
        const st = p.status === 'ativo' ? '<span class="text-green-600">ativo</span>' : `<span class="text-gray-400">${p.status}</span>`;
        pt.insertAdjacentHTML('beforeend',
          `<tr class="border-b border-gray-50">
            <td class="py-2 pr-2">${p.nome}</td>
            <td class="py-2 pr-2">${st}</td>
            <td class="py-2 pr-2">${p.leads_total}</td>
            <td class="py-2 text-gray-500">${p.ultimo_lead ? fmtData(p.ultimo_lead) : '—'}</td>
          </tr>`);
      });

      // Últimos leads
      const lt = document.getElementById('leads-tabela')!;
      if (!data.ultimos_leads?.length) show('leads-vazio');
      (data.ultimos_leads || []).forEach((l: any) => {
        lt.insertAdjacentHTML('beforeend',
          `<tr class="border-b border-gray-50">
            <td class="py-2 pr-3 text-gray-500 whitespace-nowrap">${fmtData(l.created_at)}</td>
            <td class="py-2 pr-3">${l.nome_cliente || '—'}</td>
            <td class="py-2 pr-3">${l.telefone_cliente || '—'}</td>
            <td class="py-2 pr-3">${l.cidade || '—'}</td>
            <td class="py-2 pr-3">${l.tipo_servico || '—'}</td>
          </tr>`);
      });

      show('dash');
    } catch (e) {
      hide('loading');
      show('negado');
    }
  })();
</script>
