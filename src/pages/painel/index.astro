---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: profissional } = await supabase
  .from('profissionais')
  .select('*')
  .eq('email', session.user.email)
  .single();

const { data: leads } = await supabase
  .from('leads')
  .select('*')
  .eq('profissional_id', profissional?.id)
  .order('created_at', { ascending: false })
  .limit(20);

const { data: avaliacoes } = await supabase
  .from('avaliacoes')
  .select('*')
  .eq('profissional_id', profissional?.id)
  .eq('is_published', true);

const mediaNotas = avaliacoes && avaliacoes.length > 0
  ? (avaliacoes.reduce((s, a) => s + a.nota, 0) / avaliacoes.length).toFixed(1)
  : '-';

const statusLabel: Record<string, string> = {
  novo: 'Novo',
  visualizado: 'Visualizado',
  respondido: 'Respondido',
  concluido: 'Concluído',
};
const statusColor: Record<string, string> = {
  novo: 'bg-blue-100 text-blue-800',
  visualizado: 'bg-yellow-100 text-yellow-800',
  respondido: 'bg-purple-100 text-purple-800',
  concluido: 'bg-green-100 text-green-800',
};
---
<BaseLayout title="Meu Painel — PortaFácil">
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container">

      <!-- Header do painel -->
      <div class="flex flex-wrap items-start justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Olá, {profissional?.nome?.split(' ')[0]}!</h1>
          <p class="text-gray-500 mt-1 flex items-center gap-2">
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${profissional?.plano === 'pro' ? 'bg-accent-100 text-accent-800' : 'bg-gray-100 text-gray-600'}`}>
              {profissional?.plano === 'pro' ? '⭐ Plano Pro' : 'Plano Básico'}
            </span>
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${profissional?.status === 'ativo' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800'}`}>
              {profissional?.status === 'ativo' ? 'Ativo' : 'Pendente'}
            </span>
          </p>
        </div>
        {profissional?.plano === 'basico' && (
          <a href="/planos" class="btn-primary text-sm">Fazer upgrade para Pro</a>
        )}
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        {[
          { label: 'Leads este mês', valor: profissional?.leads_mes_atual ?? 0 },
          { label: 'Total de leads', valor: leads?.length ?? 0 },
          { label: 'Avaliações', valor: avaliacoes?.length ?? 0 },
          { label: 'Nota média', valor: mediaNotas },
        ].map(s => (
          <div class="bg-white border border-gray-200 rounded-xl p-4">
            <p class="text-xs text-gray-500 mb-1">{s.label}</p>
            <p class="text-2xl font-bold text-primary-600">{s.valor}</p>
          </div>
        ))}
      </div>

      <!-- Leads recentes -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
          <h2 class="font-semibold text-gray-900">Leads recentes</h2>
          <span class="text-xs text-gray-400">{leads?.length ?? 0} no total</span>
        </div>

        {!leads || leads.length === 0 ? (
          <div class="py-16 text-center text-gray-400">
            <p class="font-medium">Nenhum lead ainda</p>
            <p class="text-sm mt-1">Quando clientes solicitarem orçamento, aparecerão aqui.</p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
                <tr>
                  <th class="text-left px-5 py-3">Cliente</th>
                  <th class="text-left px-5 py-3">Serviço</th>
                  <th class="text-left px-5 py-3">Cidade</th>
                  <th class="text-left px-5 py-3">Data</th>
                  <th class="text-left px-5 py-3">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {leads.map((lead) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-5 py-3">
                      <p class="font-medium text-gray-900">{lead.nome_cliente}</p>
                      <p class="text-gray-400 text-xs">{lead.telefone_cliente}</p>
                    </td>
                    <td class="px-5 py-3 text-gray-600">{lead.tipo_servico}</td>
                    <td class="px-5 py-3 text-gray-600">{lead.cidade}</td>
                    <td class="px-5 py-3 text-gray-400">
                      {new Date(lead.created_at).toLocaleDateString('pt-BR')}
                    </td>
                    <td class="px-5 py-3">
                      <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${statusColor[lead.status]}`}>
                        {statusLabel[lead.status]}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>
