---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="Meu Painel — PortaFácil" description="Gerencie seu perfil profissional no PortaFácil.">
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-4xl">

      <!-- Loading -->
      <div id="loading" class="text-center py-20">
        <div class="inline-block animate-spin rounded-full h-10 w-10 border-4 border-orange-500 border-t-transparent"></div>
        <p class="text-gray-500 mt-4">Carregando seu painel...</p>
      </div>

      <!-- Painel (oculto até carregar) -->
      <div id="painel" class="hidden">

        <!-- Mensagens -->
        <div id="msg-sucesso" class="hidden bg-green-50 border border-green-200 rounded-lg p-3 mb-4 text-sm text-green-700"></div>
        <div id="msg-erro" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 mb-4 text-sm text-red-700"></div>

        <!-- Banner assinatura (só aparece se não tiver plano ativo) -->
        <div id="banner-assinar" class="hidden bg-gradient-to-r from-orange-500 to-orange-600 rounded-2xl p-6 mb-8 text-white">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
              <h2 class="text-xl font-bold mb-1">🔒 Seu perfil ainda não está visível</h2>
              <p class="text-orange-100 text-sm mb-2">Assine um plano para ativar seu perfil e aparecer nas buscas de clientes.</p>
              <div class="flex flex-wrap gap-3 text-sm">
                <span>✅ Leads ilimitados</span>
                <span>✅ Destaque na busca</span>
                <span>✅ Selo verificado</span>
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <button onclick="assinar('basico')" class="bg-white text-orange-600 font-bold px-6 py-2.5 rounded-lg hover:bg-orange-50 transition-colors text-sm whitespace-nowrap">Básico — R$ 79/mês</button>
              <button onclick="assinar('pro')" class="bg-orange-800 text-white font-bold px-6 py-2.5 rounded-lg hover:bg-orange-900 transition-colors text-sm whitespace-nowrap">Pro — R$ 149/mês ⭐</button>
            </div>
          </div>
        </div>

        <!-- Banner trial -->
        <div id="banner-trial" class="hidden bg-blue-50 border border-blue-200 rounded-xl p-4 mb-8 text-sm text-blue-800">
          ⏳ Você está no período de teste gratuito. <span id="trial-dias" class="font-bold"></span> Assine um plano para não perder a visibilidade.
        </div>

        <!-- Status ativo -->
        <div id="banner-ativo" class="hidden bg-green-50 border border-green-200 rounded-xl p-4 mb-8 text-sm text-green-800">
          ✅ Seu perfil está <strong>ativo e visível</strong> nas buscas! Plano: <span id="plano-nome" class="font-bold"></span>
        </div>

        <!-- Cabeçalho perfil -->
        <div class="flex items-center gap-4 mb-8">
          <div class="relative">
            <div id="foto-container" class="w-20 h-20 rounded-full bg-orange-100 flex items-center justify-center text-2xl font-bold text-orange-600 overflow-hidden">
              <span id="foto-iniciais"></span>
              <img id="foto-img" class="hidden w-full h-full object-cover" alt="Foto de perfil" />
            </div>
            <label for="foto-input" class="absolute -bottom-1 -right-1 bg-orange-500 text-white rounded-full w-7 h-7 flex items-center justify-center cursor-pointer hover:bg-orange-600 text-sm" title="Alterar foto">📷</label>
            <input type="file" id="foto-input" accept="image/jpeg,image/png,image/webp" class="hidden" />
          </div>
          <div>
            <h1 id="nome-display" class="text-2xl font-bold text-gray-900"></h1>
            <p id="email-display" class="text-gray-500 text-sm"></p>
          </div>
          <button id="btn-sair" class="ml-auto text-sm text-gray-400 hover:text-gray-600 underline">Sair</button>
        </div>

        <!-- Métricas -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
          <div class="card"><div class="flex items-center justify-between"><div><p class="text-3xl font-bold" id="stat-leads">0</p><p class="text-sm text-gray-500">Leads recebidos<br/><span class="text-xs">Este mês</span></p></div><span class="text-2xl">📩</span></div></div>
          <div class="card"><div class="flex items-center justify-between"><div><p class="text-3xl font-bold" id="stat-views">0</p><p class="text-sm text-gray-500">Visualizações<br/><span class="text-xs">Do seu perfil</span></p></div><span class="text-2xl">👁️</span></div></div>
          <div class="card"><div class="flex items-center justify-between"><div><p class="text-3xl font-bold" id="stat-aval">0</p><p class="text-sm text-gray-500">Avaliações<br/><span class="text-xs">Média de clientes</span></p></div><span class="text-2xl">⭐</span></div></div>
        </div>

        <!-- Formulário de edição de perfil -->
        <div class="card mb-8">
          <h2 class="text-xl font-bold text-gray-900 mb-6">Editar meu perfil</h2>
          <form id="form-perfil" class="grid grid-cols-1 md:grid-cols-2 gap-4" novalidate>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nome completo</label>
              <input type="text" id="f-nome" class="input-field" required />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp</label>
              <input type="tel" id="f-whatsapp" class="input-field" placeholder="(11) 99999-9999" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">CPF ou CNPJ</label>
              <input type="text" id="f-cpf" class="input-field" placeholder="Necessário para assinatura" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Anos de experiência</label>
              <input type="number" id="f-anos" class="input-field" min="1" max="60" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Cidade</label>
              <input type="text" id="f-cidade" class="input-field" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
              <select id="f-estado" class="input-field">
                <option>AC</option><option>AL</option><option>AP</option><option>AM</option><option>BA</option><option>CE</option><option>DF</option><option>ES</option><option>GO</option><option>MA</option><option>MT</option><option>MS</option><option>MG</option><option>PA</option><option>PB</option><option>PR</option><option>PE</option><option>PI</option><option>RJ</option><option>RN</option><option>RS</option><option>RO</option><option>RR</option><option>SC</option><option>SP</option><option>SE</option><option>TO</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipos de porta</label>
              <select id="f-tipos" class="input-field">
                <option value="automatica">Automática</option>
                <option value="manual">Manual</option>
                <option value="ambas">Automática e Manual</option>
              </select>
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Descrição dos seus serviços</label>
              <textarea id="f-descricao" rows="4" class="input-field" placeholder="Conte sua experiência, especialidades, regiões que atende..."></textarea>
            </div>
            <div class="md:col-span-2">
              <button type="submit" id="btn-salvar" class="btn-primary">Salvar alterações</button>
            </div>
          </form>
        </div>

        <div class="flex gap-3">
          <a href="/profissionais" class="btn-secondary">Ver todos os profissionais</a>
          <a href="https://wa.me/5511999999999" class="btn-secondary">Falar com suporte</a>
        </div>
      </div>

      <!-- Não logado -->
      <div id="nao-logado" class="hidden text-center py-20">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Faça login para acessar seu painel</h1>
        <p class="text-gray-500 mb-6">Você precisa estar logado para ver e editar seu perfil.</p>
        <a href="/login" class="btn-primary">Ir para o login</a>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const sbUrl = document.querySelector('meta[name="sb-url"]')?.getAttribute('content') || '';
  const sbKey = document.querySelector('meta[name="sb-key"]')?.getAttribute('content') || '';

  let accessToken = '';
  let profissional: any = null;

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
  function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }
  function setText(id: string, text: string) { const el = document.getElementById(id); if (el) el.textContent = text; }

  function msgOk(m: string) { const el = document.getElementById('msg-sucesso')!; el.textContent = m; el.classList.remove('hidden'); hide('msg-erro'); setTimeout(() => el.classList.add('hidden'), 4000); }
  function msgErr(m: string) { const el = document.getElementById('msg-erro')!; el.textContent = m; el.classList.remove('hidden'); hide('msg-sucesso'); }

  async function init() {
    const { createClient } = await import('@supabase/supabase-js');
    const supabase = createClient(sbUrl, sbKey);

    const { data: { session } } = await supabase.auth.getSession();
    hide('loading');

    if (!session) { show('nao-logado'); return; }
    accessToken = session.access_token;

    const res = await fetch('/api/painel-dados', { headers: { 'Authorization': `Bearer ${accessToken}` } });
    if (!res.ok) { show('nao-logado'); return; }

    const { profissional: prof } = await res.json();
    profissional = prof;
    render(prof);
    show('painel');

    document.getElementById('btn-sair')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/login';
    });
  }

  function render(p: any) {
    setText('nome-display', p.nome || 'Complete seu perfil');
    setText('email-display', p.email);

    if (p.foto_url) {
      const img = document.getElementById('foto-img') as HTMLImageElement;
      img.src = p.foto_url;
      img.classList.remove('hidden');
      hide('foto-iniciais');
    } else {
      const iniciais = (p.nome || p.email).split(' ').map((s: string) => s[0]).slice(0, 2).join('').toUpperCase();
      setText('foto-iniciais', iniciais);
    }

    // Status/banners
    const temPlano = p.asaas_subscription_id && p.status === 'ativo';
    const emTrial = p.status === 'trial' && p.trial_ends_at && new Date(p.trial_ends_at) > new Date();

    if (p.status === 'ativo') {
      show('banner-ativo');
      setText('plano-nome', p.plano === 'pro' ? 'Pro ⭐' : 'Básico');
    } else if (emTrial) {
      show('banner-trial');
      const dias = Math.ceil((new Date(p.trial_ends_at).getTime() - Date.now()) / 86400000);
      setText('trial-dias', `Restam ${dias} dia${dias !== 1 ? 's' : ''}.`);
      show('banner-assinar');
    } else {
      show('banner-assinar');
    }

    // Preencher formulário
    (document.getElementById('f-nome') as HTMLInputElement).value = p.nome || '';
    (document.getElementById('f-whatsapp') as HTMLInputElement).value = p.whatsapp || '';
    (document.getElementById('f-cpf') as HTMLInputElement).value = p.cpf_cnpj || '';
    (document.getElementById('f-anos') as HTMLInputElement).value = p.anos_experiencia || 1;
    (document.getElementById('f-cidade') as HTMLInputElement).value = p.cidade || '';
    (document.getElementById('f-estado') as HTMLSelectElement).value = p.estado || 'SP';
    (document.getElementById('f-tipos') as HTMLSelectElement).value = p.tipos_porta || 'ambas';
    (document.getElementById('f-descricao') as HTMLTextAreaElement).value = p.descricao || '';
  }

  // Salvar perfil
  document.getElementById('form-perfil')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-salvar') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Salvando...';

    const body = {
      nome: (document.getElementById('f-nome') as HTMLInputElement).value,
      whatsapp: (document.getElementById('f-whatsapp') as HTMLInputElement).value,
      cpf_cnpj: (document.getElementById('f-cpf') as HTMLInputElement).value,
      anos_experiencia: (document.getElementById('f-anos') as HTMLInputElement).value,
      cidade: (document.getElementById('f-cidade') as HTMLInputElement).value,
      estado: (document.getElementById('f-estado') as HTMLSelectElement).value,
      tipos_porta: (document.getElementById('f-tipos') as HTMLSelectElement).value,
      descricao: (document.getElementById('f-descricao') as HTMLTextAreaElement).value,
    };

    try {
      const res = await fetch('/api/atualizar-perfil', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${accessToken}` },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      msgOk('Perfil atualizado com sucesso!');
      setText('nome-display', body.nome);
    } catch (err: any) {
      msgErr(err.message || 'Erro ao salvar');
    } finally {
      btn.disabled = false; btn.textContent = 'Salvar alterações';
    }
  });

  // Upload de foto
  document.getElementById('foto-input')?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    if (file.size > 3 * 1024 * 1024) { msgErr('Imagem muito grande (máx. 3MB)'); return; }

    const reader = new FileReader();
    reader.onload = async () => {
      try {
        const res = await fetch('/api/atualizar-perfil', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${accessToken}` },
          body: JSON.stringify({ foto_base64: reader.result }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error);
        const img = document.getElementById('foto-img') as HTMLImageElement;
        img.src = data.foto_url;
        img.classList.remove('hidden');
        hide('foto-iniciais');
        msgOk('Foto atualizada!');
      } catch (err: any) {
        msgErr(err.message || 'Erro ao enviar foto');
      }
    };
    reader.readAsDataURL(file);
  });

  // Assinar plano
  async function assinar(plano: string) {
    if (!profissional?.cpf_cnpj) {
      msgErr('Preencha seu CPF/CNPJ no formulário abaixo antes de assinar.');
      document.getElementById('f-cpf')?.focus();
      return;
    }
    try {
      const res = await fetch('/api/assinar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${accessToken}` },
        body: JSON.stringify({ plano }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error);
      window.location.href = data.url;
    } catch (err: any) {
      msgErr(err.message || 'Erro ao iniciar assinatura');
    }
  }
  (window as any).assinar = assinar;

  init();
</script>
