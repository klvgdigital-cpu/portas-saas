---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { createClient } from '@supabase/supabase-js';

// Usar service role no servidor para evitar problemas de auth
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

// Verificar se há parâmetro de cadastro bem-sucedido
const cadastroSucesso = Astro.url.searchParams.get('cadastro') === 'sucesso';

// Por ora, mostrar painel de demonstração até implementar auth completo
// TODO: implementar autenticação por cookie/session
const profissional = null;
const leads = [];
const avaliacoes = [];
---
<BaseLayout title="Painel do Profissional — PortaFácil">
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-4xl">

      {cadastroSucesso && (
        <div class="bg-green-50 border border-green-200 rounded-xl p-5 mb-8 flex items-start gap-3">
          <span class="text-2xl">🎉</span>
          <div>
            <p class="font-semibold text-green-900">Cadastro realizado com sucesso!</p>
            <p class="text-green-700 text-sm mt-1">Seu perfil está ativo e já aparece nas buscas. Em breve você receberá leads de clientes na sua região.</p>
          </div>
        </div>
      )}

      <div class="text-center py-20">
        <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1e3a5f" stroke-width="1.5">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 mb-3">Área do Profissional</h1>
        <p class="text-gray-500 mb-8 max-w-md mx-auto">O painel completo com seus leads, métricas e configurações de perfil estará disponível em breve.</p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-2xl mx-auto mb-8">
          {[
            { icon: '📩', label: 'Leads recebidos', desc: 'Veja todos os clientes que solicitaram orçamento' },
            { icon: '⭐', label: 'Avaliações', desc: 'Acompanhe sua reputação na plataforma' },
            { icon: '📊', label: 'Métricas', desc: 'Visualizações do perfil e conversões' },
          ].map(item => (
            <div class="bg-white border border-gray-200 rounded-xl p-5 text-left">
              <span class="text-2xl">{item.icon}</span>
              <p class="font-semibold text-gray-900 mt-2 mb-1">{item.label}</p>
              <p class="text-xs text-gray-500">{item.desc}</p>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/profissionais" class="btn-primary">Ver meu perfil público</a>
          <a href="mailto:contato@portafacil.net" class="btn-outline">Falar com suporte</a>
        </div>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>
