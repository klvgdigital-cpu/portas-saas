---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

const cadastroSucesso = Astro.url.searchParams.get('cadastro') === 'sucesso';
const assinaturaSucesso = Astro.url.searchParams.get('assinatura') === 'sucesso';

// Tentar pegar sessão do usuário logado
let profissional = null;
try {
  const cookieHeader = Astro.request.headers.get('cookie') || '';
  
  // Tenta todos os padrões de cookie do Supabase
  const cookieParts = cookieHeader.split(';').map(c => c.trim());
  let accessToken: string | null = null;

  for (const part of cookieParts) {
    const [key, ...rest] = part.split('=');
    const value = rest.join('=');
    if (key && key.trim().match(/sb-.+-auth-token/)) {
      try {
        const decoded = decodeURIComponent(value);
        // Formato array ["access_token","refresh_token",...]
        if (decoded.startsWith('[')) {
          const arr = JSON.parse(decoded);
          accessToken = arr[0] || null;
        } else {
          const obj = JSON.parse(decoded);
          accessToken = obj?.access_token || null;
        }
        if (accessToken) break;
      } catch {}
    }
    // Formato base64 chunk (sb-xxx-auth-token.0, .1)
    if (key && key.trim().match(/sb-.+-auth-token\.\d+/)) {
      // Será remontado abaixo
    }
  }

  // Fallback: remontar chunks base64 sb-xxx-auth-token.0 + .1
  if (!accessToken) {
    const chunks: Record<string, string> = {};
    for (const part of cookieParts) {
      const eqIdx = part.indexOf('=');
      const key = part.slice(0, eqIdx).trim();
      const value = part.slice(eqIdx + 1);
      const chunkMatch = key.match(/^(sb-.+-auth-token)\.(\d+)$/);
      if (chunkMatch) {
        chunks[chunkMatch[2]] = value;
      }
    }
    if (Object.keys(chunks).length > 0) {
      const joined = Object.keys(chunks).sort().map(k => chunks[k]).join('');
      try {
        const decoded = decodeURIComponent(joined);
        if (decoded.startsWith('[')) {
          const arr = JSON.parse(decoded);
          accessToken = arr[0] || null;
        } else {
          const obj = JSON.parse(decoded);
          accessToken = obj?.access_token || null;
        }
      } catch {}
    }
  }

  if (accessToken) {
    const { data: { user } } = await supabase.auth.getUser(accessToken);
    if (user?.email) {
      const { data } = await supabase
        .from('profissionais')
        .select('*')
        .eq('email', user.email)
        .single();
      profissional = data;
    }
  }
} catch (e) {
  // Silently fail — painel mostra estado genérico
}

const temPlano = profissional?.stripe_subscription_id || profissional?.plano === 'pro' || (profissional?.plano === 'basico' && profissional?.status === 'ativo');

// Calcular trial
const trialEndsAt = profissional?.trial_ends_at ? new Date(profissional.trial_ends_at) : null;
const hoje = new Date();
const emTrial = trialEndsAt && trialEndsAt > hoje && !profissional?.stripe_subscription_id;
const diasRestantesTrial = emTrial ? Math.ceil((trialEndsAt.getTime() - hoje.getTime()) / (1000 * 60 * 60 * 24)) : 0;
const trialExpirado = trialEndsAt && trialEndsAt <= hoje && !profissional?.stripe_subscription_id;
---
<BaseLayout title="Painel do Profissional — PortaFácil">
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-4xl">

      <!-- Sucesso cadastro -->
      {cadastroSucesso && profissional?.status === 'ativo' && (
        <div class="bg-green-50 border border-green-200 rounded-xl p-5 mb-6 flex items-start gap-3">
          <span class="text-2xl">🎉</span>
          <div>
            <p class="font-semibold text-green-900">Cadastro realizado! Seu perfil já está ativo.</p>
            <p class="text-green-700 text-sm mt-1">{emTrial ? 'Você tem ' + diasRestantesTrial + ' dias grátis para testar a plataforma. Assine um plano para continuar aparecendo nas buscas.' : 'Você já aparece nas buscas de clientes. Assine um plano para receber mais leads e ter destaque.'}</p>
          </div>
        </div>
      )}

      <!-- Banner de trial expirando -->
      {emTrial && !cadastroSucesso && (
        <div class={`rounded-xl p-5 mb-6 flex items-start gap-3 ${diasRestantesTrial <= 2 ? 'bg-red-50 border border-red-200' : 'bg-yellow-50 border border-yellow-200'}`}>
          <span class="text-2xl">{diasRestantesTrial <= 2 ? '🚨' : '⏳'}</span>
          <div>
            <p class={`font-semibold ${diasRestantesTrial <= 2 ? 'text-red-900' : 'text-yellow-900'}`}>
              {diasRestantesTrial <= 2 ? 'Seu trial expira em ' + diasRestantesTrial + (diasRestantesTrial === 1 ? ' dia!' : ' dias!') : 'Trial gratuito: ' + diasRestantesTrial + ' dias restantes'}
            </p>
            <p class={`text-sm mt-1 ${diasRestantesTrial <= 2 ? 'text-red-700' : 'text-yellow-700'}`}>Assine um plano para continuar visível nas buscas após o período gratuito.</p>
          </div>
        </div>
      )}

      <!-- Trial expirado sem assinatura -->
      {trialExpirado && profissional?.status !== 'ativo' && (
        <div class="bg-red-50 border border-red-200 rounded-xl p-5 mb-6 flex items-start gap-3">
          <span class="text-2xl">🔒</span>
          <div>
            <p class="font-semibold text-red-900">Seu período gratuito terminou</p>
            <p class="text-red-700 text-sm mt-1">Seu perfil foi desativado. Assine um plano para voltar a aparecer nas buscas de clientes.</p>
          </div>
        </div>
      )}

      {cadastroSucesso && profissional?.status !== 'ativo' && (
        <div class="bg-orange-50 border border-orange-200 rounded-xl p-5 mb-6 flex items-start gap-3">
          <span class="text-2xl">⏳</span>
          <div>
            <p class="font-semibold text-orange-900">Cadastro recebido! Falta um passo para ativar seu perfil.</p>
            <p class="text-orange-700 text-sm mt-1">Seu perfil ainda não aparece nas buscas. Assine um plano abaixo para ativá-lo.</p>
          </div>
        </div>
      )}

      <!-- Sucesso assinatura -->
      {assinaturaSucesso && (
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-6 flex items-start gap-3">
          <span class="text-2xl">🚀</span>
          <div>
            <p class="font-semibold text-blue-900">Assinatura ativada com sucesso!</p>
            <p class="text-blue-700 text-sm mt-1">Seu plano está ativo. Agora você tem acesso a todos os benefícios.</p>
          </div>
        </div>
      )}

      <!-- Banner de upgrade (só para quem não tem plano pago) -->
      {!temPlano && !assinaturaSucesso && (
        <div class="bg-gradient-to-r from-orange-500 to-orange-600 rounded-2xl p-6 mb-8 text-white">
          <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
            <div>
              {profissional?.status === 'ativo' ? (
                <>
                  <p class="font-bold text-lg mb-1">⚡ Receba mais clientes com um plano</p>
                  <p class="text-orange-100 text-sm">Seu perfil está ativo, mas com um plano você aparece em destaque e recebe leads ilimitados.</p>
                </>
              ) : (
                <>
                  <p class="font-bold text-lg mb-1">🔒 Seu perfil ainda não está visível</p>
                  <p class="text-orange-100 text-sm">Assine um plano para ativar seu perfil e aparecer nas buscas de clientes.</p>
                </>
              )}
              <div class="flex gap-4 mt-3 text-sm">
                <span class="flex items-center gap-1">✅ Leads ilimitados</span>
                <span class="flex items-center gap-1">✅ Destaque na busca</span>
                <span class="flex items-center gap-1">✅ Selo verificado</span>
              </div>
            </div>
            <div class="flex flex-col gap-2 min-w-fit" id="upgrade-buttons">
              <button onclick="assinar('basico')" class="bg-white text-orange-600 font-bold px-6 py-2.5 rounded-lg hover:bg-orange-50 transition-colors text-sm whitespace-nowrap">
                Básico — R$ 79/mês
              </button>
              <button onclick="assinar('pro')" class="bg-orange-800 text-white font-bold px-6 py-2.5 rounded-lg hover:bg-orange-900 transition-colors text-sm whitespace-nowrap">
                Pro — R$ 149/mês ⭐
              </button>
            </div>
          </div>
        </div>
      )}

      <!-- Cabeçalho do painel -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">
            {profissional ? `Olá, ${profissional.nome.split(' ')[0]}!` : 'Meu Painel'}
          </h1>
          {profissional && (
            <p class="text-sm text-gray-500 mt-1">
              <span class={`font-medium ${profissional.status === 'ativo' ? (emTrial ? 'text-yellow-600' : 'text-green-600') : 'text-orange-500'}`}>
                {profissional.status === 'ativo' 
                  ? (emTrial ? '⏳ Trial — ' + diasRestantesTrial + ' dias restantes' : '🟢 Visível nas buscas') 
                  : '🔒 Perfil não visível (pendente)'}
              </span>
              {' · '}Plano: <span class={`font-medium ${temPlano ? 'text-green-600' : 'text-gray-400'}`}>
                {temPlano ? (profissional.plano === 'pro' ? 'Pro ⭐' : 'Básico') : 'Sem plano ativo'}
              </span>
              {profissional.cidade && ` · ${profissional.cidade}, ${profissional.estado}`}
            </p>
          )}
        </div>
        {profissional?.status === 'ativo' && (
          <a href={`/profissionais/${profissional.slug}`} class="btn-outline text-sm" target="_blank">
            Ver perfil público →
          </a>
        )}
      </div>

      <!-- Cards de métricas -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        {[
          { icon: '📩', label: 'Leads recebidos', valor: '0', desc: 'Este mês' },
          { icon: '👁️', label: 'Visualizações', valor: '0', desc: 'Do seu perfil' },
          { icon: '⭐', label: 'Avaliações', valor: '0', desc: 'Média de clientes' },
        ].map(card => (
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <div class="flex items-center justify-between mb-3">
              <span class="text-2xl">{card.icon}</span>
              <span class="text-2xl font-bold text-gray-900">{card.valor}</span>
            </div>
            <p class="font-medium text-gray-900 text-sm">{card.label}</p>
            <p class="text-xs text-gray-400 mt-0.5">{card.desc}</p>
          </div>
        ))}
      </div>

      <!-- Próximos passos -->
      <div class="bg-white border border-gray-200 rounded-xl p-6">
        <h2 class="font-semibold text-gray-900 mb-4">Próximos passos para atrair mais clientes</h2>
        <div class="space-y-3">
          {[
            { feito: profissional?.foto_url, texto: 'Adicione uma foto de perfil profissional', acao: 'Adicionar foto' },
            { feito: profissional?.descricao?.length > 50, texto: 'Complete sua descrição de serviços', acao: 'Editar perfil' },
            { feito: temPlano, texto: 'Assine um plano para aparecer em destaque', acao: 'Ver planos' },
          ].map(passo => (
            <div class={`flex items-center gap-3 p-3 rounded-lg ${passo.feito ? 'bg-green-50' : 'bg-gray-50'}`}>
              <span class={`w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 ${passo.feito ? 'bg-green-500 text-white' : 'bg-gray-300 text-gray-600'}`}>
                {passo.feito ? '✓' : '•'}
              </span>
              <p class={`text-sm flex-1 ${passo.feito ? 'text-green-700 line-through' : 'text-gray-700'}`}>{passo.texto}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Links úteis -->
      <div class="flex flex-col sm:flex-row gap-3 mt-6">
        <a href="/profissionais" class="btn-outline text-sm text-center">Ver todos os profissionais</a>
        <a href="mailto:contato@portafacil.net" class="btn-outline text-sm text-center">Falar com suporte</a>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  async function assinar(plano) {
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = 'Aguarde...';

    // Pegar e-mail do usuário logado via Supabase
    try {
      const { createClient } = await import('https://esm.sh/@supabase/supabase-js@2');
      const supabase = createClient(
        document.querySelector('meta[name="sb-url"]')?.content || '',
        document.querySelector('meta[name="sb-key"]')?.content || ''
      );
      
      const { data: { session } } = await supabase.auth.getSession();
      const email = session?.user?.email;

      if (!email) {
        window.location.href = '/login?redirect=/painel';
        return;
      }

      const res = await fetch('/api/assinar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, plano }),
      });

      const json = await res.json();
      if (json.url) {
        window.location.href = json.url;
      } else {
        throw new Error(json.error || 'Erro ao iniciar assinatura');
      }
    } catch (err) {
      alert('Erro: ' + err.message);
      btn.disabled = false;
      btn.textContent = plano === 'pro' ? 'Pro — R$ 149/mês ⭐' : 'Básico — R$ 79/mês';
    }
  }

  window.assinar = assinar;
</script>
