---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Entrar — PortaFácil"
  description="Acesse sua conta na PortaFácil."
>
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Entrar na sua conta</h1>
        <p class="text-gray-500">Acesse o painel de profissional</p>
      </div>
      <div class="card">
        <div id="msg-erro" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 mb-4 text-sm text-red-700"></div>
        <div id="msg-sucesso" class="hidden bg-green-50 border border-green-200 rounded-lg p-3 mb-4 text-sm text-green-700"></div>

        <form id="form-login" class="space-y-4" novalidate>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="email">E-mail</label>
            <input id="email" type="email" name="email" required class="input-field" placeholder="voce@email.com" />
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-sm font-medium text-gray-700" for="senha">Senha</label>
              <button type="button" id="btn-esqueci" class="text-xs text-primary-600 hover:underline">Esqueceu a senha?</button>
            </div>
            <input id="senha" type="password" name="senha" required class="input-field" placeholder="••••••••" />
          </div>
          <button type="submit" id="btn-login" class="btn-primary w-full">Entrar</button>
        </form>
      </div>
      <p class="text-center text-sm text-gray-500 mt-4">
        Não tem conta? <a href="/cadastro" class="text-primary-600 hover:underline font-medium">Cadastre-se</a>
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = document.querySelector('meta[name="sb-url"]')?.getAttribute('content') || '';
  const supabaseKey = document.querySelector('meta[name="sb-key"]')?.getAttribute('content') || '';

  async function getSupabase() {
    const { createClient } = await import('@supabase/supabase-js');
    return createClient(supabaseUrl, supabaseKey);
  }

  const form = document.getElementById('form-login');
  const btnLogin = document.getElementById('btn-login') as HTMLButtonElement;
  const msgErro = document.getElementById('msg-erro') as HTMLElement;
  const msgSucesso = document.getElementById('msg-sucesso') as HTMLElement;

  function showErro(msg: string) {
    msgErro.textContent = msg;
    msgErro.classList.remove('hidden');
    msgSucesso.classList.add('hidden');
  }

  function showSucesso(msg: string) {
    msgSucesso.textContent = msg;
    msgSucesso.classList.remove('hidden');
    msgErro.classList.add('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const senha = (document.getElementById('senha') as HTMLInputElement).value;

    if (!email || !senha) {
      showErro('Preencha e-mail e senha.');
      return;
    }

    btnLogin.disabled = true;
    btnLogin.textContent = 'Entrando...';

    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(supabaseUrl, supabaseKey);

      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password: senha,
      });

      if (error || !data.session) {
        showErro('E-mail ou senha incorretos. Verifique seus dados.');
        btnLogin.disabled = false;
        btnLogin.textContent = 'Entrar';
        return;
      }

      showSucesso('Login realizado! Redirecionando...');
      setTimeout(() => { window.location.href = '/painel'; }, 500);

    } catch (err) {
      showErro('Erro ao conectar. Tente novamente.');
      btnLogin.disabled = false;
      btnLogin.textContent = 'Entrar';
    }
  });

  // Recuperação de senha
  document.getElementById('btn-esqueci')?.addEventListener('click', async () => {
    const email = (document.getElementById('email') as HTMLInputElement).value;
    if (!email) {
      showErro('Digite seu e-mail primeiro para recuperar a senha.');
      return;
    }

    try {
      const res = await fetch('/api/auth/recuperar-senha', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      showSucesso('E-mail de recuperação enviado! Verifique sua caixa de entrada.');
    } catch {
      showErro('Erro ao enviar e-mail de recuperação.');
    }
  });
</script>

<script>
  // redirect-se-logado: usuário autenticado não deve ver esta página
  (async () => {
    try {
      const u = document.querySelector('meta[name="sb-url"]')?.getAttribute('content') || '';
      const k = document.querySelector('meta[name="sb-key"]')?.getAttribute('content') || '';
      if (!u || !k) return;
      const { createClient } = await import('@supabase/supabase-js');
      const sb = createClient(u, k);
      const { data: { session } } = await sb.auth.getSession();
      if (session) window.location.replace('/painel');
    } catch {}
  })();
</script>
