---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const plano = Astro.url.searchParams.get('plano') ?? 'basico';

const estados = [
  'AC','AL','AP','AM','BA','CE','DF','ES','GO','MA','MT','MS',
  'MG','PA','PB','PR','PE','PI','RJ','RN','RS','RO','RR','SC','SP','SE','TO'
];
---
<BaseLayout
  title="Cadastre-se como Profissional — PortaFácil"
  description="Crie sua conta na PortaFácil e comece a receber clientes que precisam de porta de enrolar na sua cidade."
  breadcrumbs={[{label:'Home',href:'/'},{label:'Cadastro',href:'/cadastro-profissional'}]}
>
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-2xl">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Cadastre-se como profissional</h1>
        <p class="text-gray-500">Preencha seus dados e comece a receber clientes hoje</p>
      </div>

      <div class="card">
        <form id="form-cadastro" class="space-y-5" novalidate>
          <input type="hidden" name="plano" value={plano} />

          <fieldset class="space-y-4">
            <legend class="font-semibold text-gray-900 text-sm uppercase tracking-wide pb-2 border-b border-gray-100 w-full">Dados pessoais</legend>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="nome">Nome completo *</label>
                <input id="nome" type="text" name="nome" required class="input-field" placeholder="João da Silva" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="cpf_cnpj">CPF ou CNPJ *</label>
                <input id="cpf_cnpj" type="text" name="cpf_cnpj" required class="input-field" placeholder="000.000.000-00" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="email">E-mail *</label>
                <input id="email" type="email" name="email" required class="input-field" placeholder="voce@email.com" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="whatsapp">WhatsApp *</label>
                <input id="whatsapp" type="tel" name="whatsapp" required class="input-field" placeholder="(11) 99999-0000" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="senha">Senha *</label>
              <input id="senha" type="password" name="senha" required class="input-field" placeholder="Mínimo 8 caracteres" minlength="8" />
            </div>
          </fieldset>

          <fieldset class="space-y-4">
            <legend class="font-semibold text-gray-900 text-sm uppercase tracking-wide pb-2 border-b border-gray-100 w-full">Sobre seus serviços</legend>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="descricao">Descrição dos serviços *</label>
              <textarea id="descricao" name="descricao" rows="4" required class="input-field resize-none" placeholder="Descreva sua experiência, tipos de serviço que realiza, marcas que atende..."></textarea>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="tipos_porta">Tipo de porta *</label>
                <select id="tipos_porta" name="tipos_porta" class="input-field">
                  <option value="ambas">Automática e Manual</option>
                  <option value="automatica">Somente Automática</option>
                  <option value="manual">Somente Manual</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="anos_experiencia">Anos de experiência *</label>
                <select id="anos_experiencia" name="anos_experiencia" class="input-field">
                  {[1,2,3,5,10,15,20].map(n => (
                    <option value={n}>{n}+ anos</option>
                  ))}
                </select>
              </div>
            </div>
          </fieldset>

          <fieldset class="space-y-4">
            <legend class="font-semibold text-gray-900 text-sm uppercase tracking-wide pb-2 border-b border-gray-100 w-full">Localização</legend>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="cidade">Cidade principal *</label>
                <input id="cidade" type="text" name="cidade" required class="input-field" placeholder="São Paulo" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="estado">Estado *</label>
                <select id="estado" name="estado" class="input-field">
                  {estados.map(uf => <option value={uf}>{uf}</option>)}
                </select>
              </div>
            </div>
          </fieldset>

          <!-- Seletor de plano inline -->
          <fieldset class="space-y-3">
            <legend class="font-semibold text-gray-900 text-sm uppercase tracking-wide pb-2 border-b border-gray-100 w-full">Escolha seu plano</legend>
            <label class="flex items-start gap-3 p-4 rounded-lg border-2 border-primary-300 bg-primary-50 cursor-pointer" id="label-basico">
              <input type="radio" name="plano" value="basico" class="mt-1 accent-primary-600" id="plano-basico" />
              <div class="flex-1">
                <p class="font-semibold text-gray-900">Plano Básico — <span class="text-primary-600">R$ 79/mês</span></p>
                <p class="text-xs text-gray-500 mt-0.5">Até 10 leads/mês · Perfil ativo na plataforma</p>
              </div>
            </label>
            <label class="flex items-start gap-3 p-4 rounded-lg border-2 border-gray-200 bg-white cursor-pointer" id="label-pro">
              <input type="radio" name="plano" value="pro" class="mt-1 accent-accent-500" id="plano-pro" />
              <div class="flex-1">
                <div class="flex items-center justify-between">
                  <p class="font-semibold text-gray-900">Plano Pro — <span class="text-accent-500">R$ 149/mês</span></p>
                  <span class="text-xs font-medium bg-accent-500 text-white px-2 py-0.5 rounded-full">Recomendado</span>
                </div>
                <p class="text-xs text-gray-500 mt-0.5">Leads ilimitados · Destaque · Selo Verificado · Agendamento online</p>
              </div>
            </label>
          </fieldset>

          <div class="flex items-start gap-3">
            <input type="checkbox" id="termos" name="termos" required class="mt-1 w-4 h-4 accent-primary-600" />
            <label for="termos" class="text-sm text-gray-600">
              Li e aceito os <a href="/termos" class="text-primary-600 hover:underline">Termos de Uso</a> e a
              <a href="/privacidade" class="text-primary-600 hover:underline">Política de Privacidade</a>
            </label>
          </div>

          <button type="submit" class="btn-primary w-full text-base">
            Criar conta e prosseguir para pagamento
          </button>

          <p class="text-xs text-gray-400 text-center">
            Após o cadastro, você será redirecionado para o pagamento seguro via Stripe.
          </p>
        </form>
      </div>

      <p class="text-center text-sm text-gray-500 mt-4">
        Já tem conta? <a href="/login" class="text-primary-600 hover:underline font-medium">Entrar</a>
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Pré-selecionar plano baseado na URL
  const params = new URLSearchParams(window.location.search);
  const planoInicial = params.get('plano') || 'basico';
  const radioInicial = document.querySelector(`input[name="plano"][value="${planoInicial}"]`);
  if (radioInicial) radioInicial.checked = true;
  atualizarPlano(planoInicial);

  // Destacar plano selecionado
  document.querySelectorAll('input[name="plano"]').forEach(radio => {
    radio.addEventListener('change', (e) => atualizarPlano(e.target.value));
  });

  function atualizarPlano(plano) {
    const labelBasico = document.getElementById('label-basico');
    const labelPro = document.getElementById('label-pro');
    if (plano === 'pro') {
      labelPro.className = 'flex items-start gap-3 p-4 rounded-lg border-2 border-accent-400 bg-orange-50 cursor-pointer';
      labelBasico.className = 'flex items-start gap-3 p-4 rounded-lg border-2 border-gray-200 bg-white cursor-pointer';
    } else {
      labelBasico.className = 'flex items-start gap-3 p-4 rounded-lg border-2 border-primary-300 bg-primary-50 cursor-pointer';
      labelPro.className = 'flex items-start gap-3 p-4 rounded-lg border-2 border-gray-200 bg-white cursor-pointer';
    }
  }

  const form = document.getElementById('form-cadastro');
  const btn = form?.querySelector('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const plano = data.get('plano');
    const nome = data.get('nome');
    const email = data.get('email');

    btn.disabled = true;
    btn.textContent = 'Aguarde...';

    try {
      // Salvar profissional no Supabase
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        document.querySelector('meta[name="sb-url"]')?.content || '',
        document.querySelector('meta[name="sb-key"]')?.content || ''
      );

      const slug = nome.toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '') + '-' + Date.now();

      await supabase.from('profissionais').insert({
        slug,
        nome,
        email,
        whatsapp: data.get('whatsapp'),
        cpf_cnpj: data.get('cpf_cnpj'),
        descricao: data.get('descricao'),
        cidade: data.get('cidade'),
        estado: data.get('estado'),
        tipos_porta: data.get('tipos_porta'),
        anos_experiencia: Number(data.get('anos_experiencia')),
        plano: 'basico',
        status: 'pendente',
      });

      // Redirecionar para Stripe Checkout
      const res = await fetch('/api/stripe-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plano, email, nome }),
      });

      const json = await res.json();

      if (!json.url) throw new Error(json.error || 'Erro ao criar sessão de pagamento');

      window.location.href = json.url;

    } catch (err) {
      alert('Erro: ' + (err.message || 'Tente novamente.'));
      btn.disabled = false;
      btn.textContent = 'Criar conta e prosseguir para pagamento';
    }
  });
</script>
