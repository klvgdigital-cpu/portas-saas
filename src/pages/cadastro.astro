---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const estados = [
  'AC','AL','AP','AM','BA','CE','DF','ES','GO','MA','MT','MS',
  'MG','PA','PB','PR','PE','PI','RJ','RN','RS','RO','RR','SC','SP','SE','TO'
];
---
<BaseLayout
  title="Cadastre-se como Profissional — PortaFácil"
  description="Crie sua conta na PortaFácil gratuitamente e comece a receber clientes que precisam de porta de enrolar na sua cidade."
  breadcrumbs={[{label:'Home',href:'/'},{label:'Cadastro',href:'/cadastro'}]}
>
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-2xl">

      <!-- Header da página -->
      <div class="text-center mb-8">
        <span class="inline-block bg-green-100 text-green-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-4">Cadastro gratuito</span>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Crie seu perfil profissional</h1>
        <p class="text-gray-500">Preencha seus dados e apareça nas buscas de clientes hoje mesmo</p>
      </div>

      <!-- Benefícios rápidos -->
      <div class="grid grid-cols-3 gap-3 mb-8">
        {[
          { icon: '⚡', text: 'Ativação imediata' },
          { icon: '🔍', text: 'Apareça nas buscas' },
          { icon: '💳', text: 'Sem cartão agora' },
        ].map(b => (
          <div class="bg-white rounded-xl border border-gray-100 p-3 text-center">
            <span class="text-xl">{b.icon}</span>
            <p class="text-xs font-medium text-gray-700 mt-1">{b.text}</p>
          </div>
        ))}
      </div>

      <div class="card">
        <form id="form-cadastro" class="space-y-5" novalidate>

          <!-- Dados pessoais -->
          <fieldset class="space-y-4">
            <legend class="font-semibold text-gray-900 text-sm uppercase tracking-wide pb-2 border-b border-gray-100 w-full">Dados pessoais</legend>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="nome">Nome completo *</label>
                <input id="nome" type="text" name="nome" required class="input-field" placeholder="João da Silva" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="cpf_cnpj">CPF ou CNPJ</label>
                <input id="cpf_cnpj" type="text" name="cpf_cnpj" class="input-field" placeholder="000.000.000-00" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="email">E-mail *</label>
                <input id="email" type="email" name="email" required class="input-field" placeholder="voce@email.com" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="whatsapp">WhatsApp *</label>
                <input id="whatsapp" type="tel" name="whatsapp" required class="input-field" placeholder="(11) 99999-0000" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="senha">Senha *</label>
              <input id="senha" type="password" name="senha" required class="input-field" placeholder="Mínimo 8 caracteres" minlength="8" />
              <div id="senha-rules" class="mt-2 space-y-1 hidden">
                <p id="rule-len" class="text-xs flex items-center gap-1.5 text-gray-400"><span id="icon-len">○</span> Mínimo 8 caracteres</p>
                <p id="rule-upper" class="text-xs flex items-center gap-1.5 text-gray-400"><span id="icon-upper">○</span> Pelo menos 1 letra maiúscula</p>
                <p id="rule-number" class="text-xs flex items-center gap-1.5 text-gray-400"><span id="icon-number">○</span> Pelo menos 1 número</p>
              </div>
            </div>
          </fieldset>

          <!-- Serviços -->
          <fieldset class="space-y-4">
            <legend class="font-semibold text-gray-900 text-sm uppercase tracking-wide pb-2 border-b border-gray-100 w-full">Sobre seus serviços</legend>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" for="descricao">Descrição dos serviços *</label>
              <textarea id="descricao" name="descricao" rows="3" required class="input-field resize-none" placeholder="Descreva sua experiência, tipos de serviço, marcas que atende..."></textarea>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="tipos_porta">Tipo de porta *</label>
                <select id="tipos_porta" name="tipos_porta" class="input-field">
                  <option value="ambas">Automática e Manual</option>
                  <option value="automatica">Somente Automática</option>
                  <option value="manual">Somente Manual</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="anos_experiencia">Anos de experiência *</label>
                <select id="anos_experiencia" name="anos_experiencia" class="input-field">
                  {[1,2,3,5,10,15,20].map(n => (
                    <option value={n}>{n}+ anos</option>
                  ))}
                </select>
              </div>
            </div>
          </fieldset>

          <!-- Localização -->
          <fieldset class="space-y-4">
            <legend class="font-semibold text-gray-900 text-sm uppercase tracking-wide pb-2 border-b border-gray-100 w-full">Regiões que você atende *</legend>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="cidade">Cidade principal *</label>
                <input id="cidade" type="text" name="cidade" required class="input-field" placeholder="São Paulo" />
              </div>
            </div>

            <p class="text-sm text-gray-500">Marque todas as regiões onde você atende — é assim que os clientes vão te encontrar:</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm" id="regioes-grupo">
              {['Zona Norte (SP capital)','Zona Sul (SP capital)','Zona Leste (SP capital)','Zona Oeste (SP capital)','Centro (SP capital)','ABC','Guarulhos','Osasco e região','Outras cidades da Grande SP','Atendo também fora da Grande SP'].map(r => (
                <label class="flex items-center gap-2 text-gray-700 border border-gray-200 rounded-lg px-3 py-2 hover:border-orange-300 cursor-pointer">
                  <input type="checkbox" name="regiao-opt" value={r} class="w-4 h-4 accent-primary-600" /> {r}
                </label>
              ))}
            </div>
            <p id="regioes-erro" class="hidden text-sm text-red-600">Selecione pelo menos uma região.</p>
            <input type="hidden" name="estado" value="SP" />
          </fieldset>

          <!-- Termos -->
          <div class="flex items-start gap-3">
            <input type="checkbox" id="termos" name="termos" required class="mt-1 w-4 h-4 accent-primary-600" />
            <label for="termos" class="text-sm text-gray-600">
              Li e aceito os <a href="/termos" class="text-primary-600 hover:underline">Termos de Uso</a> e a
              <a href="/privacidade" class="text-primary-600 hover:underline">Política de Privacidade</a>
            </label>
          </div>

          <!-- Erro -->
          <div id="form-erro" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700"></div>

          <!-- Botão -->
          <button type="submit" id="btn-submit" class="btn-primary w-full text-base">
            Começar 10 dias grátis →
          </button>

          <p class="text-xs text-gray-400 text-center">
            Sem cartão de crédito agora. Seu perfil fica ativo por 10 dias gratuitos — assine um plano para continuar.
          </p>
        </form>
      </div>

      <p class="text-center text-sm text-gray-500 mt-4">
        Já tem conta? <a href="/login" class="text-primary-600 hover:underline font-medium">Entrar</a>
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Validação de senha
  const senhaInput = document.getElementById('senha');
  const senhaRules = document.getElementById('senha-rules');

  function updateRule(id, iconId, valid) {
    const el = document.getElementById(id);
    const icon = document.getElementById(iconId);
    if (valid) {
      el.classList.replace('text-gray-400', 'text-green-600');
      icon.textContent = '✓';
    } else {
      el.classList.replace('text-green-600', 'text-gray-400');
      icon.textContent = '○';
    }
  }

  senhaInput?.addEventListener('focus', () => senhaRules?.classList.remove('hidden'));
  senhaInput?.addEventListener('input', (e) => {
    const v = e.target.value;
    updateRule('rule-len', 'icon-len', v.length >= 8);
    updateRule('rule-upper', 'icon-upper', /[A-Z]/.test(v));
    updateRule('rule-number', 'icon-number', /[0-9]/.test(v));
  });

  // Submit
  const form = document.getElementById('form-cadastro');
  const btn = document.getElementById('btn-submit');
  const erroDiv = document.getElementById('form-erro');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    btn.disabled = true;
    btn.textContent = 'Criando sua conta...';
    erroDiv.classList.add('hidden');

    const data = new FormData(form);

    try {
      const regioesMarcadas = data.getAll('regiao-opt');
      const erroRegioes = document.getElementById('regioes-erro');
      if (regioesMarcadas.length === 0) {
        erroRegioes?.classList.remove('hidden');
        document.getElementById('regioes-grupo')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        throw new Error('Selecione pelo menos uma região que você atende.');
      }
      erroRegioes?.classList.add('hidden');

      const res = await fetch('/api/cadastro', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nome: data.get('nome'),
          email: data.get('email'),
          senha: data.get('senha'),
          whatsapp: data.get('whatsapp'),
          cpf_cnpj: data.get('cpf_cnpj'),
          descricao: data.get('descricao'),
          cidade: data.get('cidade'),
          estado: data.get('estado'),
          regioes: data.getAll('regiao-opt').join(', '),
          aceite_termos: true,
          tipos_porta: data.get('tipos_porta'),
          anos_experiencia: data.get('anos_experiencia'),
        }),
      });

      const json = await res.json();

      if (!res.ok || !json.success) {
        throw new Error(json.error || 'Erro ao criar conta');
      }

      window.location.href = '/painel?cadastro=sucesso';

    } catch (err) {
      erroDiv.textContent = err.message || 'Erro inesperado. Tente novamente.';
      erroDiv.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Criar minha conta grátis →';
    }
  });
</script>

<script>
  // redirect-se-logado: usuário autenticado não deve ver esta página
  (async () => {
    try {
      const u = document.querySelector('meta[name="sb-url"]')?.getAttribute('content') || '';
      const k = document.querySelector('meta[name="sb-key"]')?.getAttribute('content') || '';
      if (!u || !k) return;
      const { createClient } = await import('@supabase/supabase-js');
      const sb = createClient(u, k);
      const { data: { session } } = await sb.auth.getSession();
      if (session) window.location.replace('/painel');
    } catch {}
  })();
</script>
