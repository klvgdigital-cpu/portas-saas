---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProfissionalBySlug } from '../../lib/supabase';

const { slug } = Astro.params;

let profissional;
try {
  profissional = await getProfissionalBySlug(slug!);
} catch {
  return Astro.redirect('/profissionais');
}

if (profissional.plano !== 'pro') {
  return Astro.redirect(`/profissionais/${slug}`);
}
---
<BaseLayout
  title={`Agendar visita — ${profissional.nome} — PortaFácil`}
  description={`Agende uma visita técnica com ${profissional.nome} em ${profissional.cidade}`}
>
  <Header />
  <main class="section bg-gray-50 min-h-screen">
    <div class="container max-w-lg">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Agendar visita técnica</h1>
        <p class="text-gray-500">com <strong>{profissional.nome}</strong> em {profissional.cidade}</p>
      </div>
      <div class="card">
        <form id="form-agendamento" class="space-y-4">
          <input type="hidden" name="profissional_id" value={profissional.id} />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Seu nome</label>
            <input type="text" name="nome" required class="input-field" placeholder="Nome completo" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Telefone / WhatsApp</label>
            <input type="tel" name="telefone" required class="input-field" placeholder="(11) 99999-0000" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Data preferida</label>
            <input type="date" name="data" required class="input-field" min={new Date().toISOString().split('T')[0]} />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de serviço</label>
            <select name="tipo_servico" class="input-field">
              <option>Manutenção / reparo</option>
              <option>Instalação nova</option>
              <option>Motorização</option>
              <option>Emergência</option>
              <option>Outro</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Descrição</label>
            <textarea name="descricao" rows="3" class="input-field resize-none" placeholder="Descreva o problema..."></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">Confirmar agendamento</button>
        </form>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
