---
import type { Profissional } from '../lib/supabase';

interface Props {
  profissional: Profissional;
}

const { profissional } = Astro.props;

const tiposLabel: Record<string, string> = {
  automatica: 'Automática',
  manual: 'Manual',
  ambas: 'Automática e Manual',
};

const initials = profissional.nome.split(' ').map(n => n[0]).slice(0, 2).join('').toUpperCase();
---
<a
  href={`/profissionais/${profissional.slug}`}
  class="card flex flex-col gap-4 group"
  aria-label={`Ver perfil de ${profissional.nome}`}
>
  <div class="flex items-start gap-4">
    <!-- Foto / Avatar -->
    <div class="shrink-0 w-16 h-16 rounded-xl overflow-hidden bg-primary-50 flex items-center justify-center">
      {profissional.foto_url
        ? <img src={profissional.foto_url} alt={`Foto de ${profissional.nome}`} class="w-full h-full object-cover" loading="lazy" width="64" height="64" />
        : <span class="text-primary-600 font-bold text-lg">{initials}</span>
      }
    </div>

    <!-- Info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-2">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors truncate">
          {profissional.nome}
        </h3>
        {profissional.plano === 'pro' && (
          <span class="badge-pro shrink-0">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Pro
          </span>
        )}
      </div>
      <p class="text-sm text-gray-500 mt-0.5 flex items-center gap-1">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {profissional.cidade}, {profissional.estado}
      </p>
    </div>
  </div>

  <!-- Badges -->
  <div class="flex flex-wrap gap-2">
    <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">
      {tiposLabel[profissional.tipos_porta]}
    </span>
    <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">
      {profissional.anos_experiencia}+ anos
    </span>
    {profissional.plano === 'pro' && (
      <span class="badge-verificado">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Verificado
      </span>
    )}
  </div>

  <!-- Descrição -->
  <p class="text-sm text-gray-600 line-clamp-2 leading-relaxed">{profissional.descricao}</p>

  <span class="text-sm font-medium text-primary-600 group-hover:text-accent-500 transition-colors flex items-center gap-1">
    Ver perfil
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </span>
</a>
